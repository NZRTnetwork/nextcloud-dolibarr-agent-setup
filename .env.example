# ── Nextcloud ─────────────────────────────────────────────────────────────────
NC_URL=https://your-nextcloud.com/nextcloud
NC_USER=admin
NC_PASSWORD=your-admin-password
NC_APP_TOKEN=your-app-token-here       # generate in NC Settings → Security → App passwords

# ── WordPress ─────────────────────────────────────────────────────────────────
WP_URL=https://yoursite.com
WP_USER=admin
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx   # generate in WP Admin → Users → Application Passwords

# ── Dolibarr ──────────────────────────────────────────────────────────────────
# Used by create_agents.py and set_dolibarr_permissions.py (direct MySQL)
MYSQL_BIN=mysql                        # full path if not in PATH, e.g. C:/laragon/bin/mysql/.../mysql.exe
DB_NAME=dolibarr
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=                               # leave blank if no root password

# ── cPanel SSH (optional — only needed for email account creation) ─────────────
CPANEL_SSH_HOST=your-server.com
CPANEL_SSH_USER=cpanel_username
CPANEL_SSH_KEY=/path/to/private_key
CPANEL_SSH_PASSPHRASE=                 # leave blank if key has no passphrase
CPANEL_DOMAIN=yourdomain.com

# ── Credentials output ────────────────────────────────────────────────────────
CREDS_PATH=agent_credentials.txt      # where create_agents.py saves generated passwords

# ── Agent Nextcloud usernames ─────────────────────────────────────────────────
AGENT_PAM=pam
AGENT_CAS=cas
AGENT_SUN=sun
AGENT_FIN=fin
AGENT_HAN=han
AGENT_EMA=ema
AGENT_DAI=dai
AGENT_DAN=dan

# ── Agent passwords ───────────────────────────────────────────────────────────
# Set after running create_agents.py (it generates and saves these)
# Used by cleanup_nc_defaults.py (authenticates as each agent)
AGENT_PAM_PASS=changeme
AGENT_CAS_PASS=changeme
AGENT_SUN_PASS=changeme
AGENT_FIN_PASS=changeme
AGENT_HAN_PASS=changeme
AGENT_EMA_PASS=changeme
AGENT_DAI_PASS=changeme
AGENT_DAN_PASS=changeme
